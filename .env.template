PORT=3003
NODE_ENV=development

# Base de datos (PostgreSQL)
# Local (docker compose):  postgresql://canchas_user:canchas_pass@localhost:5432/canchas_db
# Supabase (prod):         usar el connection string del Session Pooler (IPv4, puerto 5432)
DATABASE_URL=postgresql://canchas_user:canchas_pass@localhost:5432/canchas_db
# false en local; true en Supabase/prod (requiere SSL)
DATABASE_SSL=false

# Secreto interno: el gateway (y los otros microservicios) lo mandan en cada llamada.
# Debe ser IDÉNTICO en gateway y en los 4 microservicios.
INTERNAL_SECRET=secreto_largo_para_seguridad_en_microservicios

# URLs de otros microservicios
# Local: http://localhost:300X   |   Prod: URLs públicas en Render
USUARIOS_URL=http://localhost:3001
CANCHAS_URL=http://localhost:3002

# Reglas de negocio (sobreescriben configuraciones de BD si se definen)
SENA_PORCENTAJE_DEFAULT=30
HORAS_ANTICIPACION_MIN=2
DURACION_MAXIMA_HORAS=3
